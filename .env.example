# Claude authentication (one of the two required)
CLAUDE_CODE_OAUTH_TOKEN=     # from: claude setup-token
ANTHROPIC_API_KEY=           # from: console.anthropic.com

# Telegram
TELEGRAM_BOT_TOKEN=          # from: @BotFather
TELEGRAM_ONLY=true           # set true if not using WhatsApp

# Gemini (for paper-scout skill)
GEMINI_API_KEY=              # from: aistudio.google.com/apikey

# Twitter/X (stored in groups/main/.twitter_api_config, not here)
# TWITTER_CONSUMER_KEY=
# TWITTER_CONSUMER_SECRET=
# TWITTER_BEARER_TOKEN=
# TWITTER_ACCESS_TOKEN=
# TWITTER_ACCESS_TOKEN_SECRET=
# TWITTER_CLIENT_ID=
# TWITTER_CLIENT_SECRET=
# TWITTER_USERNAME=          # also in groups/main/.twitter_config
# TWITTER_PASSWORD=          # also in groups/main/.twitter_config
